  eventData:
  - {fileID: 11400000, guid: 594f61bbbde127943ba903d3109b2b05, type: 2}
  dialogueLines:
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: Finally arived huh?
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
          Data4: 0
        Path: 
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: How did I get here before you?
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
          Data4: 0
        Path: 
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: Different angles, faster launch, that sort of stuff.
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
          Data4: 0
        Path: 
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: More importantly, welcome to <color=blue>Iregular Peak</color>.
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
          Data4: 0
        Path: 
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: Theres a key that we need from this area.
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
          Data4: 0
        Path: 
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: Last I saw it was somewhere at the top of this mountain.
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
          Data4: 0
        Path: 
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: Head on up there and come back when you've got it.
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
          Data4: 0
        Path: 
  - dialogueSpeakerDatum: {fileID: 11400000, guid: 898383444ddfe8447aa8ed4370564c42, type: 2}
    text: Oh, and don't keep me waiting too long. My time is money.
    hasVoiceActing: 0
    eventReference:
      eventRef:
        Guid:
          Data1: 0
          Data2: 0
          Data3: 0
